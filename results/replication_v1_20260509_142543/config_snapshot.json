{
  "experiment_name": "replication_v1",
  "dataset_path": "data/football_matches.csv",
  "target_column": "target",
  "date_column": "match_date",
  "test_size": 0.2,
  "seed": 42,
  "top_k_features": 20,
  "outlier_cap": 0.95,
  "use_temporal_split": true,
  "run_cv": true,
  "cv_folds": 5,
  "models": [
    {
      "name": "random_forest",
      "params": {
        "n_estimators": 100,
        "max_depth": 10
      }
    },
    {
      "name": "xgboost",
      "params": {
        "n_estimators": 150,
        "learning_rate": 0.1,
        "max_depth": 6
      }
    },
    {
      "name": "adaboost",
      "params": {
        "n_estimators": 200,
        "learning_rate": 0.8
      }
    }
  ],
  "settings": {
    "run_imbalanced": true,
    "run_smote": true
  },
  "output_root": "results"
}